{
  "name": "universal-media-downloader",
  "version": "0.0.1",
  "description": "A minimalist, dark-mode media downloader.",
  "main": "./out/main/index.js",
  "author": "Universal Media Downloader",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "prepackage": "node scripts/prepare-resources.mjs",
    "build:unpack": "npm run build && npm run prepackage && electron-builder --dir",
    "build:win": "npm run build && npm run prepackage && electron-builder --win"
  },
  "devDependencies": {
    "@fontsource-variable/cairo": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "gsap": "^3.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3"
  },
  "dependencies": {
    "yauzl": "^3.3.2"
  }
}
